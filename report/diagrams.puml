' ============================================================
'  1. CONTEXT LEVEL DIAGRAM (Level 0 DFD)
' ============================================================
@startuml context_diagram

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam ArrowColor #10B981
skinparam RectangleBorderColor #334155
skinparam RectangleBackgroundColor #F1F5F9

rectangle "User\n(Browser)" as User #E0F2FE
rectangle "Admin\n(Data Manager)" as Admin #FEF3C7

package "TennisLytics System" as System #E8FFF5 {
    rectangle "Tennis Analytics\nDashboard" as App #10B981
}

database "MongoDB\n(Atlas / Local)" as DB #F1F5F9
file "ATP CSV\nData Source" as CSV #FEF3C7

User --> App : HTTP Requests\n(Browse, Search,\nFilter, Compare)
App --> User : JSON Responses\n(Players, Stats,\nCharts Data)

Admin --> App : POST/PUT/DELETE\n(Manage Players)
Admin --> CSV : Provides\nCSV Data

App --> DB : Mongoose Queries\n(CRUD, Aggregation)
DB --> App : Query Results\n(Documents, Pipelines)

CSV --> App : Seed Script\n(Parse & Ingest)

@enduml


