' ============================================================
'  10. STATE DIAGRAM - Player Search
' ============================================================
@startuml state_search

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam StateBorderColor #10B981

[*] --> Idle

state Idle {
    Idle : Search box empty
    Idle : Dropdown closed
}

Idle --> Focused : User clicks\nsearch box

state Focused {
    Focused : Cursor active
    Focused : Dropdown open\n(showing top 30 players)
}

Focused --> Filtering : User types\ncharacters

state Filtering {
    Filtering : Real-time client-side\nregex match
    Filtering : Results update\ninstantly
}

Filtering --> Filtering : More chars typed
Filtering --> Selected : User clicks\nor presses Enter

state Selected {
    Selected : Player ID stored
    Selected : Name displayed
    Selected : Dropdown closed
}

Selected --> Focused : User clicks\n"x" to clear

Focused --> Idle : Click outside\nor press Escape

Filtering --> Idle : Press Escape

@enduml

