' ============================================================
'  6. SEQUENCE DIAGRAM - Head-to-Head Flow
' ============================================================
@startuml sequence_h2h

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam SequenceArrowColor #10B981
skinparam ParticipantBorderColor #334155

actor User as U
participant "React\nHeadToHead.jsx" as FE
participant "SearchableSelect\nComponent" as SS
participant "Express\nAPI Server" as API
database "MongoDB" as DB

U -> FE : Navigate to /head-to-head
activate FE

FE -> API : GET /api/players
activate API
API -> DB : Player.find().sort()
DB --> API : [1477 players]
API --> FE : { players, totalCount }
deactivate API

U -> SS : Type "Thiem"
activate SS
SS -> SS : Filter players\n(client-side regex)
SS --> U : Show dropdown:\n"Dominic Thiem"
U -> SS : Select "Dominic Thiem"
SS --> FE : onChange(player1Id)
deactivate SS

U -> SS : Type "Moutet"
activate SS
SS --> U : Show "Corentin Moutet"
U -> SS : Select player
SS --> FE : onChange(player2Id)
deactivate SS

U -> FE : Click "Compare"
FE -> API : GET /api/matches/head-to-head\n?player1=id1&player2=id2
activate API

API -> DB : Match.aggregate([\n  $match ($or),\n  $lookup (winner),\n  $unwind,\n  $lookup (loser),\n  $unwind,\n  $project\n])
activate DB
DB --> API : [matched documents]
deactivate DB

API -> API : Compute p1Wins,\np2Wins counts
API --> FE : { totalMatches,\nplayer1Wins,\nplayer2Wins,\nmatches[] }
deactivate API

FE -> FE : Render summary cards\n+ match history table
FE --> U : Display H2H results
deactivate FE

@enduml


' ============================================================
'  7. ACTIVITY DIAGRAM - Match Explorer
' ============================================================
@startuml activity_explorer

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam ActivityBorderColor #10B981

start

:User navigates to\n/match-explorer;

:Load default filter\n(6-0 Sweeps);

:Fetch matches from API\nGET /api/matches/sweeps;

:Display results in table\nwith match count;

repeat
    :User clicks a\nfilter button;

    if (Filter type?) then (Sweeps)
        :Query: **$elemMatch**\n{ winnerScore: 6,\n  loserScore: 0 };
    elseif (Tiebreakers) then
        :Query: **$elemMatch**\n{ tiebreak: true };
    elseif (Close Sets) then
        :Query: **$elemMatch**\n{ winnerScore: 7,\n  loserScore: 5 };
    elseif (Three-Setters) then
        :Query: **$expr**\n{ $eq: [$size, 3] };
    elseif (Straight Sets) then
        :Query: **$expr**\n{ $eq: [$size, 2] };
    else (Dominant Wins)
        :Query: **$not + $elemMatch**\n{ loserScore: { $gt: 1 } };
    endif

    :Fetch from API endpoint;
    :Update table with results;
    :Display MongoDB query used;

repeat while (User explores more?) is (Yes)

stop

@enduml


' ============================================================
'  8. CLASS DIAGRAM - Mongoose Models
' ============================================================
@startuml class_diagram

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam ClassBorderColor #10B981
skinparam ClassBackgroundColor #F0FDF4

class Player {
    - _id : ObjectId
    - name : String
    - nationality : String
    - rank : Number
    - hand : String
    - createdAt : Date
    - updatedAt : Date
    --
    + find(filter) : Player[]
    + findById(id) : Player
    + create(data) : Player
    + findByIdAndUpdate(id, data) : Player
    + findByIdAndDelete(id) : Player
    + countDocuments(filter) : Number
    + distinct(field) : String[]
    + aggregate(pipeline) : Object[]
}

class Match {
    - _id : ObjectId
    - tourney_name : String
    - surface : String
    - winner_id : ObjectId <<ref Player>>
    - loser_id : ObjectId <<ref Player>>
    - sets : Set[]
    - createdAt : Date
    - updatedAt : Date
    --
    + find(filter) : Match[]
    + countDocuments(filter) : Number
    + aggregate(pipeline) : Object[]
    + populate(field) : Match
}

class Set <<embedded>> {
    - setNum : Number
    - winnerScore : Number
    - loserScore : Number
    - tiebreak : Boolean
}

Player "1" -- "0..*" Match : winner_id >
Player "1" -- "0..*" Match : loser_id >
Match "1" *-- "1..*" Set : sets (embedded) >

@enduml


