' ============================================================
'  4. ENTITY-RELATIONSHIP DIAGRAM
' ============================================================
@startuml er_diagram

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam ClassBorderColor #10B981
skinparam ClassBackgroundColor #F0FDF4

entity "Player" as Player {
    * _id : ObjectId <<PK>>
    --
    * name : String
    * nationality : String
    rank : Number
    hand : String {R, L, U}
    createdAt : Date
    updatedAt : Date
}

entity "Match" as Match {
    * _id : ObjectId <<PK>>
    --
    * tourney_name : String
    * surface : String {Hard, Clay, Grass}
    * winner_id : ObjectId <<FK>>
    * loser_id : ObjectId <<FK>>
    createdAt : Date
    updatedAt : Date
}

entity "Set (Embedded)" as SetDoc {
    * setNum : Number
    --
    * winnerScore : Number
    * loserScore : Number
    tiebreak : Boolean
}

Player ||--o{ Match : "wins >"
Player ||--o{ Match : "loses >"
Match ||--|{ SetDoc : "contains >"

note right of SetDoc
    Embedded sub-document
    (no separate collection)
    _id: false
end note

@enduml


